{
  "id": "case-007",
  "version": 1,
  "created_at": "2026-03-21",
  "prompt": "マークダウンファイルを読み込んで、見出し構造をツリー形式で表示するCLIツールを作ってください。",
  "category": {
    "task_type": "new_repo",
    "ambiguity": "medium"
  },
  "fixture": {
    "type": "none"
  },
  "expectations": [
    {
      "id": "e1",
      "type": "response_type",
      "expected": "new_repo"
    },
    {
      "id": "e2",
      "type": "file_count_min",
      "min": 2
    },
    {
      "id": "e3",
      "type": "content_contains_any_file",
      "pattern": "#|heading|Heading|header|Header"
    },
    {
      "id": "e4",
      "type": "file_present",
      "path": "README.md"
    }
  ],
  "rubric": [
    {
      "id": "r1",
      "weight": 2,
      "check_type": "content_contains_any_file",
      "indicators": {
        "strong": "os\\.Args|sys\\.argv|process\\.argv|argparse|flag\\.Parse|cobra|Args|args",
        "weak": "arg|file"
      },
      "criterion": "コマンドライン引数でファイルパスを受け取る"
    },
    {
      "id": "r2",
      "weight": 3,
      "check_type": "content_contains_any_file",
      "indicators": {
        "strong": "strings\\.HasPrefix.*\\\"#\\\"|startswith.*\\\"#\\\"|match.*^#+|regex.*^#+|/^#{1,6}/",
        "weak": "#|heading|header"
      },
      "criterion": "Markdownの見出しをパースしている"
    },
    {
      "id": "r3",
      "weight": 3,
      "check_type": "content_contains_any_file",
      "indicators": {
        "strong": "indent|Indent|level|Level|depth|Depth|├|└|│|──|repeat.*\\\" \\\"|strings\\.Repeat",
        "weak": "tree|Tree|ツリー"
      },
      "criterion": "見出しレベルに応じたインデントまたはツリー表示がある"
    },
    {
      "id": "r4",
      "weight": 1,
      "check_type": "content_contains_any_file",
      "indicators": {
        "strong": "os\\.Open.*err|os\\.ReadFile.*err|open\\(.*\\).*except|fs\\.readFile.*catch|try.*catch",
        "weak": "error|Error|err"
      },
      "criterion": "ファイル読み込みのエラーハンドリングがある"
    },
    {
      "id": "r5",
      "weight": 1,
      "check_type": "content_match",
      "path": "README.md",
      "indicators": {
        "strong": "(├|└|│|──).*#|出力例|output|Output|example|Example",
        "weak": "README"
      },
      "criterion": "READMEに出力例が含まれている"
    }
  ]
}

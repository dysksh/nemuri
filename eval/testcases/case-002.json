    },
    {
      "id": "r2",
      "weight": 3,
      "check_type": "content_match",
      "path": "internal/executor/executor.go",
      "criterion": "エラーメッセージに操作内容が含まれている",
      "indicators": {
        "strong": "fmt\\.Errorf\\(\"(save|upload|create|deliver|resume|notify|post).*:.*%w",

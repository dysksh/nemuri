{
  "name": "nemuri-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "target": "dev"
  },
  "remoteUser": "dev",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "postCreateCommand": "make setup",
  "remoteEnv": {
    "AWS_PROFILE": "${localEnv:AWS_PROFILE}",
    "AWS_REGION": "${localEnv:AWS_REGION:ap-northeast-1}"
  }
}
